<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NCAA_Power_Ratings.Mobile.Models"
             xmlns:viewmodels="clr-namespace:NCAA_Power_Ratings.Mobile.ViewModels"
             x:Class="NCAA_Power_Ratings.Mobile.Views.SchedulePage"
             x:Name="ThisPage">

    <Grid RowDefinitions="Auto,Auto,*,24">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FILTER BAR: Year + Filter pills                     -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
          ColumnDefinitions="*,*"
          Padding="10,6,10,4"
          ColumnSpacing="8"
          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}">

            <!-- Year pill -->
            <Border Grid.Column="0"
              StrokeShape="RoundRectangle 6"
              Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
              StrokeThickness="1"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
              Padding="8,3">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                 Text="{Binding SelectedYear}"
                 FontSize="13"
                 FontAttributes="Bold"
                 VerticalOptions="Center" />
                    <Label Grid.Column="1"
                 Text="▾"
                 FontSize="11"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center"
                 Margin="4,0,0,0" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectYearCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Filter pill -->
            <Border Grid.Column="1"
              StrokeShape="RoundRectangle 6"
              Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
              StrokeThickness="1"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
              Padding="8,3">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                 Text="{Binding SelectedFilter}"
                 FontSize="13"
                 FontAttributes="Bold"
                 VerticalOptions="Center"
                 LineBreakMode="TailTruncation" />
                    <Label Grid.Column="1"
                 Text="▾"
                 FontSize="11"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center"
                 Margin="4,0,0,0" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- WEEK SELECTOR: scrollable horizontal strip          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1"
                x:Name="WeekScrollView"
                Orientation="Horizontal"
                HorizontalScrollBarVisibility="Never"
                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#252525}">
            <HorizontalStackLayout Spacing="0"
                             Padding="6,0"
                             BindableLayout.ItemsSource="{Binding Weeks}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:WeekItem">
                        <Grid Padding="2,0" MinimumWidthRequest="44">
                            <VerticalStackLayout Spacing="0">

                                <!-- Week label — purple when selected -->
                                <Label Text="{Binding Label}"
                       FontSize="12"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Padding="8,6">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                 Binding="{Binding IsSelected}"
                                 Value="True">
                                            <Setter Property="TextColor"
                              Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                 Binding="{Binding IsSelected}"
                                 Value="False">
                                            <Setter Property="TextColor"
                              Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <!-- Underline — visible only when selected -->
                                <BoxView HeightRequest="2"
                         HorizontalOptions="Fill"
                         Color="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                         IsVisible="{Binding IsSelected}" />

                            </VerticalStackLayout>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectWeekCommand}"
                    CommandParameter="{Binding Week}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LOADING / EMPTY STATES                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ActivityIndicator Grid.Row="2"
                       IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

        <Label Grid.Row="2"
           Text="{Binding StatusMessage}"
           IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           FontSize="14"
           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- GAMES LIST                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <CollectionView Grid.Row="2"
                ItemsSource="{Binding Games}"
                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">

            <CollectionView.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left"
                                Command="{Binding NextWeekCommand}" />
                <SwipeGestureRecognizer Direction="Right"
                                Command="{Binding PreviousWeekCommand}" />
            </CollectionView.GestureRecognizers>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:GameResult">
                    <VerticalStackLayout Spacing="0">

                        <!-- ── Date group header ── -->
                        <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                  Padding="10,4,10,4"
                  IsVisible="{Binding ShowGroupHeader}">
                            <Label Text="{Binding GroupHeader}"
                     FontSize="11"
                     FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                     VerticalOptions="Center" />
                        </Grid>

                        <!-- ── Game card ──
                 Columns:  32  | 28 |  *   |  52           |  96
                           Wk    ☆    name   score (proj)    labeled metric
                 Row 0 = visitor:  score (proj)  |  margin: actual (proj)
                 Row 1 = home:     score (proj)  |  O/U: actual (proj)
            -->
                        <Grid ColumnDefinitions="32,28,*,52,96"
                  RowDefinitions="Auto,Auto"
                  Padding="6,5,10,5"
                  BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

                            <!-- Week — spans both rows -->
                            <Label Grid.Row="0" Grid.Column="0"
                     Grid.RowSpan="2"
                     Text="{Binding Week, StringFormat='Wk{0}'}"
                     FontSize="10"
                     TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                     HorizontalOptions="Start"
                     VerticalOptions="Center" />

                            <!-- ══ VISITOR ROW (top) ══ -->

                            <Label Grid.Row="0" Grid.Column="1"
                     Text="☆"
                     FontSize="17"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                      CommandParameter="{Binding VisitorId}" />
                                </Label.GestureRecognizers>
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding VisitorIsFollowed}" Value="True">
                                        <Setter Property="Text" Value="★" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#CC8800, Dark=#FFCC44}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding VisitorIsFollowed}" Value="False">
                                        <Setter Property="Text" Value="☆" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#BBBBBB, Dark=#555555}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Grid.Row="0" Grid.Column="2"
                     Text="{Binding VisitorName}"
                     FontSize="14"
                     VerticalOptions="Center"
                     LineBreakMode="TailTruncation" />

                            <Label Grid.Row="0" Grid.Column="3"
                     Text="{Binding DisplayVisitorScore}"
                     FontSize="13"
                     FontAttributes="Bold"
                     HorizontalOptions="End"
                     VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />

                            <Label Grid.Row="0" Grid.Column="4"
                     Text="{Binding DisplayMargin}"
                     FontSize="11"
                     HorizontalOptions="End"
                     VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

                            <!-- ══ HOME ROW (bottom) ══ -->

                            <Label Grid.Row="1" Grid.Column="1"
                     Text="☆"
                     FontSize="17"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                      CommandParameter="{Binding HomeId}" />
                                </Label.GestureRecognizers>
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HomeIsFollowed}" Value="True">
                                        <Setter Property="Text" Value="★" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#CC8800, Dark=#FFCC44}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HomeIsFollowed}" Value="False">
                                        <Setter Property="Text" Value="☆" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#BBBBBB, Dark=#555555}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Grid.Row="1" Grid.Column="2"
                     FontSize="14"
                     VerticalOptions="Center"
                     LineBreakMode="TailTruncation">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding HomeName}" />
                                        <Span Text="{Binding NeutralIndicator}"
                          FontSize="10"
                          TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label Grid.Row="1" Grid.Column="3"
                     Text="{Binding DisplayHomeScore}"
                     FontSize="13"
                     FontAttributes="Bold"
                     HorizontalOptions="End"
                     VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />

                            <Label Grid.Row="1" Grid.Column="4"
                     Text="{Binding DisplayOU}"
                     FontSize="11"
                     HorizontalOptions="End"
                     VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

                        </Grid>

                        <!-- Row divider -->
                        <BoxView HeightRequest="1"
                     Opacity="0.10"
                     Color="{AppThemeBinding Light=Black, Dark=White}" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="20">
                    <Label Text="No games found"
                 FontSize="16"
                 HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="3"
          HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">

            <Label Text="( ) = projected value"
             Padding="8,0"
             FontSize="10"
             Opacity="0.5"
             VerticalOptions="Center"
             HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         HeightRequest="16"
                         WidthRequest="16"
                         HorizontalOptions="End"
                         VerticalOptions="Center"
                         Margin="8,0" />
        </Grid>

    </Grid>
</ContentPage>
