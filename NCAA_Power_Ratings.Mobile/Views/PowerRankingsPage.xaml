<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NCAA_Power_Ratings.Mobile.ViewModels"
             xmlns:models="clr-namespace:NCAA_Power_Ratings.Mobile.Models"
             x:Class="NCAA_Power_Ratings.Mobile.Views.PowerRankingsPage"
             Title="Power Rankings">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Filter Bar -->
        <HorizontalStackLayout Grid.Row="0" 
                              Padding="10"
                              Spacing="10"
                              BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">

            <!-- Year Picker -->
            <Label Text="Year:" 
                   VerticalOptions="Center"
                   TextColor="White"
                   FontAttributes="Bold"/>
            <Picker x:Name="YearPicker"
                    WidthRequest="100"
                    SelectedIndexChanged="OnYearChanged">
                <Picker.Items>
                    <x:String>2021</x:String>
                    <x:String>2022</x:String>
                    <x:String>2023</x:String>
                    <x:String>2024</x:String>
                    <x:String>2025</x:String>
                </Picker.Items>
            </Picker>

            <!-- Conference Filter -->
            <Label Text="Conference:" 
                   VerticalOptions="Center"
                   TextColor="White"
                   FontAttributes="Bold"
                   Margin="20,0,0,0"/>
            <Picker WidthRequest="120"
                    ItemsSource="{Binding Conferences}"
                    SelectedItem="{Binding SelectedConference}" />
        </HorizontalStackLayout>

        <!-- Quick Filters -->
        <HorizontalStackLayout Grid.Row="1" 
                              Padding="10,5"
                              Spacing="10">
            <Button Text="All" 
                    Command="{Binding ApplyFilterCommand}"
                    CommandParameter="All"
                    BackgroundColor="{StaticResource Secondary}"
                    WidthRequest="80"/>
            <Button Text="Top 25" 
                    Command="{Binding ApplyFilterCommand}"
                    CommandParameter="Top25"
                    BackgroundColor="{StaticResource Secondary}"
                    WidthRequest="80"/>
            <Button Text="🔄 Refresh" 
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="{StaticResource Tertiary}"
                    WidthRequest="100"/>
        </HorizontalStackLayout>

        <!-- Rankings List -->
        <CollectionView Grid.Row="2"
                       ItemsSource="{Binding FilteredTeams}"
                       SelectionMode="Single">

                        <CollectionView.Header>
                <!-- Column Headers (tappable for sorting) -->
                <Grid Padding="10,5"
                      BackgroundColor="{AppThemeBinding Light=#f0f0f0, Dark=#2b2b2b}"
                      ColumnDefinitions="60,*,80,100,100,80">
                    
                    <!-- Rank Header -->
                    <Label Grid.Column="0" Text="Rank ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="Rank"/>
                        </Label.GestureRecognizers>
                    </Label>
                    
                    <!-- Team Header -->
                    <Label Grid.Column="1" Text="Team ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="Team"/>
                        </Label.GestureRecognizers>
                    </Label>
                    
                    <!-- Record Header -->
                    <Label Grid.Column="2" Text="Record ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="Record"/>
                        </Label.GestureRecognizers>
                    </Label>
                    
                    <!-- Rating Header -->
                    <Label Grid.Column="3" Text="Rating ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="Rating"/>
                        </Label.GestureRecognizers>
                    </Label>
                    
                    <!-- Conference Header -->
                    <Label Grid.Column="4" Text="Conference ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="Conference"/>
                        </Label.GestureRecognizers>
                    </Label>
                    
                    <!-- SOS Header -->
                    <Label Grid.Column="5" Text="SOS ?" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SortColumnCommand}"
                                                CommandParameter="SOS"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TeamRanking">
                    <Grid Padding="10,8"
                          ColumnDefinitions="60,*,80,100,100,80">

                        <!-- Rank with highlighting for Top 25 -->
                        <Border Grid.Column="0"
                                BackgroundColor="{Binding IsTop25, Converter={StaticResource BoolToColorConverter}}"
                                StrokeThickness="0"
                                Padding="8,4"
                                WidthRequest="75"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding DisplayRank}"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- Team Name -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding TeamName}"
                                   FontSize="16"
                                   FontAttributes="Bold"/>
                            <Label Text="{Binding Conference}"
                                   FontSize="12"
                                   Opacity="0.7"/>
                        </VerticalStackLayout>

                        <!-- Record -->
                        <Label Grid.Column="2"
                               Text="{Binding Record}"
                               FontSize="14"
                               VerticalOptions="Center"/>

                        <!-- Power Rating -->
                        <Label Grid.Column="3"
                               Text="{Binding DisplayRanking}"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>

                        <!-- Conference Abbreviation -->
                        <Label Grid.Column="4"
                               Text="{Binding ConferenceAbbr}"
                               FontSize="12"
                               VerticalOptions="Center"/>

                        <!-- SOS -->
                        <Label Grid.Column="5"
                               Text="{Binding DisplaySOS}"
                               FontSize="12"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Padding="20">
                    <Label Text="No teams found"
                           FontSize="18"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           Opacity="0.7"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Status Bar -->
        <BoxView Grid.Row="3" 
                 HeightRequest="1" 
                 Color="{AppThemeBinding Light=#e0e0e0, Dark=#404040}"/>
        <Label Grid.Row="3"
               Text="{Binding StatusMessage}"
               Padding="10,5"
               FontSize="12"
               Opacity="0.8"
               HorizontalOptions="Start"/>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="3"
                          IsRunning="{Binding IsBusy}"
                          IsVisible="{Binding IsBusy}"
                          HorizontalOptions="End"
                          Margin="10"/>
    </Grid>

</ContentPage>



