<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NCAA_Power_Ratings.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NCAA_Power_Ratings.Mobile"
    xmlns:views="clr-namespace:NCAA_Power_Ratings.Mobile.Views"
    Title="NCAA Power Ratings">

    <TabBar>
        <ShellContent
            Title="Rankings"
            Icon="trophy.png"
            ContentTemplate="{DataTemplate views:PowerRankingsPage}"
            Route="PowerRankingsPage" />

        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </TabBar>

</Shell>
